# ============================================================================
# EduLife Backend Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
MONGODB_URI=mongodb://localhost:27017/edulife

# ============================================================================
# AWS S3 CONFIGURATION (Required for cloud video storage)
# ============================================================================
# Get these from your AWS IAM user credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=edulife-learning-platform-2025-26-bucket

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
# AssemblyAI - For automatic caption/subtitle generation
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Gemini AI - For content simplification (cognitive mode)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
